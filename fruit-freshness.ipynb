    "import matplotlib.pyplot as plt\n",
    "from tensorflow.keras.utils import img_to_array, load_img\n",
    "\n",
    "classes = ['Fresh Apple', 'Fresh Banana', 'Fresh Orange', 'Rotten Apple', 'Rotten Banana', 'Rotten Orange']\n",
    "\n",
    "filename = r\"C:\\Users\\aishu\\Desktop\\FruitFreshnessDetectionProject\\dataset\\test\\freshapples\\rotated_by_15_Screen Shot 2018-06-08 at 4.59.49 PM.png\"\n",
    "\n",
    "try:\n",
    "    test_image = load_img(filename, target_size=(64, 64))\n",
    "    \n",
    "    plt.imshow(test_image)\n",
    "    plt.title(\"Selected Image\")\n",
    "    plt.axis(\"on\")\n",
    "    plt.show()\n",
    "\n",
    "    test_image_array = img_to_array(test_image)\n",
    "    test_image_array = test_image_array / 255.0 \n",
    "    \n",
    "    # Expand dimensions to create a batch (1, 64, 64, 3)\n",
    "    test_image_batch = np.expand_dims(test_image_array, axis=0)\n",
    "\n",
    "    # 5. Predict using the loaded model\n",
    "    result = new_model.predict(test_image_batch)\n",
    "    \n",
    "    # 6. Improved Prediction Logic\n",
    "    # np.argmax finds the index of the highest probability\n",
    "    predicted_index = np.argmax(result[0])\n",
    "    prediction = classes[predicted_index]\n",
    "    \n",
    "    # Show confidence score\n",
    "    confidence = result[0][predicted_index] * 100\n",
    "    print(f\"The prediction is: {prediction} ({confidence:.2f}% confidence)\")\n",
    "\n",
    "except FileNotFoundError:\n",
    "    print(f\"Error: The file at {filename} was not found. Please check the spelling and path.\")\n",
    "except Exception as e:\n",
    "    print(f\"An unexpected error occurred: {e}\")"
   ]
  }
